{
  "name": "radiatorrepair",
  "type": "module",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "tally": "node src/tallyLocations.js",
    "slugs": "node src/citySlugs.js",
    "cities": "node src/getCityData.js",
    "filter": "node src/scripts/cursor/filterNewJson.js",
    "log-categories": "node src/scripts/cursor/logCategories.js",
    "csv": "node src/scripts/cursor/jsonToCsv.js",
    "enrich": "node src/scripts/enrich.js",
    "build-final": "node src/scripts/buildFinal.js",
    "process": "node src/scripts/enrich.js && node src/scripts/buildFinal.js",
    "insert": "npm run insert-dev",
    "insert-dev": "cross-env NODE_ENV=development RRH_TARGET=dev node src/scripts/insert.js",
    "insert-prod": "cross-env NODE_ENV=production RRH_TARGET=prod node src/scripts/insert.js",
    "clear-cache": "node src/scripts/clearReferenceCache.js",
    "delete-batch": "node src/scripts/deleteBatch.js",
    "backfill-hours": "node src/scripts/backfillHours.js",
    "backfill-timezones": "npm run backfill-timezones-dev",
    "backfill-timezones-dev": "cross-env NODE_ENV=development RRH_TARGET=dev node src/scripts/backfillTimezones.js",
    "backfill-timezones-prod": "cross-env NODE_ENV=production RRH_TARGET=prod node src/scripts/backfillTimezones.js",
    "scrape-emails": "node src/scripts/scrapeEmails.js",
    "scrape-emails-firecrawl": "node src/scripts/scrapeEmailsFirecrawl.js",
    "cleanup-bad-emails": "npm run cleanup-bad-emails-dev",
    "cleanup-bad-emails-dev": "cross-env NODE_ENV=development node src/scripts/cleanupBadEmails.js",
    "cleanup-bad-emails-prod": "cross-env NODE_ENV=production node src/scripts/cleanupBadEmails.js",
    "sync-emails-dev": "cross-env NODE_ENV=development node src/scripts/syncEmails.js",
    "sync-emails-prod": "cross-env NODE_ENV=production node src/scripts/syncEmails.js"
  },
  "keywords": [],
