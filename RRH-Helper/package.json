  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@supabase/supabase-js": "^2.57.2",
    "dotenv": "^17.2.2",
    "firecrawl": "^4.30.1",
    "geo-tz": "^8.1.7",
    "ioredis": "^5.11.1",
    "json2csv": "^6.0.0-alpha.2",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
